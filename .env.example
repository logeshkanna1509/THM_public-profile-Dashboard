# ─── Supabase (recommended, used in production) ──────────────────────────────
# Create a project at https://supabase.com, then run supabase/schema.sql.
# The SERVICE ROLE key is used server-side and bypasses Row Level Security.
# (The ANON key also works if you keep the public RLS policies from schema.sql.)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Optional: falls back to SUPABASE_SERVICE_ROLE_KEY if unset.
SUPABASE_ANON_KEY=

# ─── App ─────────────────────────────────────────────────────────────────────
# Public base URL of the deployed app (used for canonical links/metadata).
NEXT_PUBLIC_APP_URL=http://localhost:3000
