# ─── TryHackMe fetch proxy (recommended on Vercel / any datacenter) ──────────
# TryHackMe blocks datacenter IPs (incl. Vercel) with its bot-protection. Route
# fetches through a proxy / scraping API that resolves from a trusted IP. Use
# __URL__ as a placeholder for the target, e.g.:
#   THM_PROXY_URL=https://app.scrapingbee.com/api/v1?api_key=YOUR_KEY&url=__URL__
# Or a plain endpoint that takes ?url=. Leave empty for a direct fetch (works
# only from IPs THM doesn't block).
THM_PROXY_URL=

# ─── App ─────────────────────────────────────────────────────────────────────
# Public base URL of the deployed app (used for canonical links/metadata).
NEXT_PUBLIC_APP_URL=http://localhost:3000
